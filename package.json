{
  "name": "crossmind",
  "version": "0.5.36",
  "description": "AI Agent-native CLI for 15 social platforms. Token-efficient output, multi-account, built-in safety policies.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "crossmind": "./dist/main.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "dev": "ts-node --esm src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "test:unit": "node --import tsx/esm --test test/unit.test.ts",
    "test:integration": "node --import tsx/esm --test test/integration.test.ts",
    "test:auth": "node --import tsx/esm --test --test-concurrency 1 test/authenticated.test.ts",
    "test": "node --import tsx/esm --test test/unit.test.ts test/integration.test.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "undici": "^6.19.2",
    "yaml": "^2.4.5"
  },
  "optionalDependencies": {
    "playwright": "^1.44.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "social",
    "agent",
    "ai",
    "twitter",
    "reddit",
    "github"
  ],
  "license": "MIT"
}
